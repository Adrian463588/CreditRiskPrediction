{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.1.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "graph", "name": "Graph", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "🏦 Loan Approval Rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 0.1},
              {"color": "yellow", "value": 0.3},
              {"color": "green",  "value": 0.6}
            ]
          },
          "mappings": []
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true},
      "targets": [{"expr": "loan_approval_rate", "legendFormat": "Approval Rate", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "🤖 Model Confidence Score",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 0.5},
              {"color": "green",  "value": 0.7}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true},
      "targets": [{"expr": "model_confidence_score", "legendFormat": "Confidence", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "💻 CPU Usage (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 70},
              {"color": "red",    "value": 90}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true},
      "targets": [{"expr": "system_cpu_usage_percent", "legendFormat": "CPU", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "🧠 Memory Usage (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 70},
              {"color": "red",    "value": 85}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true},
      "targets": [{"expr": "system_memory_usage_percent", "legendFormat": "Memory", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "📈 Loan Approval Rate (Timeline)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15}
        }
      },
      "options": {"tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "loan_approval_rate", "legendFormat": "Approval Rate", "refId": "A"},
        {"expr": "0.10", "legendFormat": "Alert Threshold (10%)", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "⚡ API Latency P95 (seconds)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(api_latency_seconds_bucket[5m]))", "legendFormat": "P95 Latency", "refId": "A"},
        {"expr": "histogram_quantile(0.50, rate(api_latency_seconds_bucket[5m]))", "legendFormat": "P50 Latency", "refId": "B"},
        {"expr": "2.0", "legendFormat": "Alert Threshold (2s)", "refId": "C"}
      ]
    },
    {
      "id": 7,
      "title": "📊 Request Rate (req/sec)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(api_request_total[1m])", "legendFormat": "{{endpoint}}", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "title": "🔴 HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {"expr": "rate(http_error_total[5m]) / (rate(api_request_total[5m]) + 0.001)", "legendFormat": "Error Rate", "refId": "A"},
        {"expr": "0.05", "legendFormat": "Alert Threshold (5%)", "refId": "B"}
      ]
    },
    {
      "id": 9,
      "title": "🔗 Active Connections",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 100}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [{"expr": "api_active_connections", "legendFormat": "Connections", "refId": "A"}]
    },
    {
      "id": 10,
      "title": "⚠️  Default Prediction Count",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"lineWidth": 2, "fillOpacity": 20}}
      },
      "targets": [
        {"expr": "rate(loan_default_prediction_total[5m]) * 60", "legendFormat": "Default Predictions/min", "refId": "A"}
      ]
    },
    {
      "id": 11,
      "title": "🌀 Data Drift Score",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 1,
          "custom": {"lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.3},
              {"color": "red", "value": 0.7}
            ]
          }
        }
      },
      "targets": [
        {"expr": "data_drift_score", "legendFormat": "Drift Score", "refId": "A"},
        {"expr": "0.3", "legendFormat": "Warning Threshold", "refId": "B"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["credit-risk", "mlops", "dicoding"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "adriansyah0904",
  "uid": "credit-risk-mlops-dashboard",
  "version": 1
}
